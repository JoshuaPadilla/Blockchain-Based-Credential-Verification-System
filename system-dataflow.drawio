    </mxCell>
    <mxCell id="be_auth_login" value="POST /login&#xa;Passport local strategy&#xa;bcrypt compare → issue JWT cookies (access 24h, refresh 7d)" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_auth">
      <mxGeometry x="10" y="40" width="240" height="70" as="geometry" />
    </mxCell>
    <mxCell id="be_auth_reg" value="POST /register&#xa;Hash password (bcrypt)&#xa;Generate ETH wallet keypair&#xa;Store encrypted private key" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_auth">
      <mxGeometry x="280" y="40" width="240" height="70" as="geometry" />
    </mxCell>

    <!-- Record Module -->
    <mxCell id="be_rec" value="Record Module  /record" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="be_container">
      <mxGeometry x="20" y="210" width="540" height="150" as="geometry" />
    </mxCell>
    <mxCell id="be_rec_post" value="POST /record  (Issue Credential)&#xa;1. Fetch Student + AcademicRecords + Subjects&#xa;2. Fetch CredentialType&#xa;3. Normalize data → keccak256 → dataHash&#xa;4. Generate 8-char credentialRef&#xa;5. addRecord on-chain (ref, hash, exp, typeId)&#xa;6. Save Record row (ref, dataHash, txHash)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_rec">
      <mxGeometry x="10" y="40" width="520" height="95" as="geometry" />
    </mxCell>

    <!-- Signer Module -->
    <mxCell id="be_sign" value="Signer Module  /signer" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="be_container">
      <mxGeometry x="20" y="380" width="540" height="150" as="geometry" />
    </mxCell>
    <mxCell id="be_sign_batch" value="POST /batch-sign  (Batch Sign Flow)&#xa;1. Fetch Records + credential signers&#xa;2. Fetch signer User → decrypt private key&#xa;3. Upsert RecordSignature rows (PENDING)&#xa;4. Create ethers.Wallet → batchSignRecords on-chain&#xa;5. Await TX receipt → update RecordSignature (CONFIRMED)&#xa;6. Increment Record.currentSignatures" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_sign">
      <mxGeometry x="10" y="40" width="520" height="95" as="geometry" />
    </mxCell>

    <!-- Admin Module -->
    <mxCell id="be_adm" value="Admin Module  /admin" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="be_container">
      <mxGeometry x="20" y="550" width="540" height="110" as="geometry" />
    </mxCell>
    <mxCell id="be_adm_rev" value="POST /revoke/:id  /restore/:id&#xa;Call revokeRecord / restoreRecord on-chain&#xa;UPDATE Record.revoked flag in DB" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_adm">
      <mxGeometry x="10" y="40" width="240" height="55" as="geometry" />
    </mxCell>
    <mxCell id="be_adm_signer" value="POST /set-credential-signer&#xa;setCredentialTypeSigner on-chain&#xa;Update signers join table in DB" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_adm">
      <mxGeometry x="280" y="40" width="240" height="55" as="geometry" />
    </mxCell>

    <!-- Verification Module -->
    <mxCell id="be_ver" value="Verification Module  /verification  (Public, no auth)" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="be_container">
      <mxGeometry x="20" y="680" width="540" height="130" as="geometry" />
    </mxCell>
    <mxCell id="be_ver_get" value="GET /verify/:credentialRef&#xa;[Parallel] getRecord(ref) from blockchain → { dataHash, expiration, isRevoked, currentSigs }&#xa;[Parallel] Fetch Record + Student + AcademicRecords from DB&#xa;Re-normalize student data → recompute keccak256 → compare hashes&#xa;Return: { isTampered, isRevoked, isExpired, isFullySigned, record }" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=6;" vertex="1" parent="be_ver">
      <mxGeometry x="10" y="40" width="520" height="75" as="geometry" />
    </mxCell>

